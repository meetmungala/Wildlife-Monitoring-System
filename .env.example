# Copy this file to .env and fill in your values

# Flask secret key (change in production!)
SECRET_KEY=change-me-in-production

# Database URL
# SQLite (default, no setup required):
DATABASE_URL=sqlite:///wildlife.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/wildlife_db

# MongoDB (optional – used if you swap the backend):
# MONGODB_URI=mongodb://localhost:27017/wildlife

# Flask environment
FLASK_DEBUG=false
